# Copy this to .env and fill in your values
# .env is gitignored — never commit real credentials

# Postgres (Airflow metadata DB)
POSTGRES_USER=airflow_user
POSTGRES_PASSWORD=airflow_pass
POSTGRES_DB=airflow_db

# Airflow
AIRFLOW__CORE__FERNET_KEY=          # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=     # any random string
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# SMTP (Gmail App Password)
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_app_password_16chars
AIRFLOW__SMTP__SMTP_MAIL_FROM=your_email@gmail.com

# AWS (leave empty if using IAM role on EC2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# Airflow Variables (automatically injected into Airflow when container starts)
AIRFLOW_VAR_S3_BUCKET_NAME=your-s3-bucket-name
AIRFLOW_VAR_EMAIL_RECEIVER=your_email@gmail.com
AIRFLOW_VAR_FRED_API_KEY=your_fred_api_key

# =============================================================================
# BACKEND SWITCH — change these 3 vars to toggle between PostgreSQL ↔ Snowflake
# =============================================================================
# DW_BACKEND  : controls Airflow DAGs (load + dbt target selection)
# DBT_ADAPTER : controls which dbt Docker image is used (postgres | snowflake)
# DBT_TARGET  : dbt --target flag used by dbt-docs service (dev | snowflake)
#
# ── PostgreSQL (local Docker) ─────────────────────────────────────────────
#   DW_BACKEND=postgresql  |  DBT_ADAPTER=postgres  |  DBT_TARGET=dev
#
# ── Snowflake (cloud) ─────────────────────────────────────────────────────
#   Step 1 — Provision infra (ONCE only, Snowflake is cloud-persistent):
#     Fill terraform/terraform.tfvars: enable_snowflake=true + credentials
#     cd terraform && terraform init && terraform apply
#     Terraform creates: CREDIT_RISK_DW / RAW+STG+PROD schemas / COMPUTE_WH / STG_LOANS
#
#   Step 2 — Switch pipeline (edit the 3 lines below + fill SNOWFLAKE_* section):
#     DW_BACKEND=snowflake  |  DBT_ADAPTER=snowflake  |  DBT_TARGET=snowflake
#     docker compose up -d
#     Airflow auto-creates 'snowflake_default' connection from SNOWFLAKE_* vars
#     (AIRFLOW_CONN_SNOWFLAKE_DEFAULT is built in docker-compose.yml — no UI needed)
#     NOTE: If SNOWFLAKE_PASSWORD has special chars (@, /, ?, #), URL-encode them first.
# =============================================================================
DW_BACKEND=postgresql
DBT_ADAPTER=postgres
DBT_TARGET=dev

# PostgreSQL DW (dedicated container, separate from Airflow metadata DB)
DW_POSTGRES_USER=dw_user
DW_POSTGRES_PASSWORD=dw_secure_pass
DW_POSTGRES_DB=credit_risk_dw
# Reachable from Airflow containers via hostname 'postgres-dw'

# Snowflake credentials (fill in when DW_BACKEND=snowflake)
# AIRFLOW_CONN_SNOWFLAKE_DEFAULT is auto-constructed from these vars in docker-compose.yml
SNOWFLAKE_ACCOUNT=your_account.ap-southeast-1
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=CREDIT_RISK_DW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@pgadmin.org
PGADMIN_DEFAULT_PASSWORD=admin

# === DOCKER-IN-DOCKER (DooD) PATH RESOLUTION ===
# Absolute path of this project ON THE HOST machine.
# Required so the Docker daemon can correctly mount the dbt/ folder
# into standalone dbt containers when triggered from Airflow.
# Example (EC2 Ubuntu): /home/ubuntu/credit-risk-monitoring-pipeline
# Example (Mac):        /Users/yourname/DE-Project/credit-risk-monitoring-pipeline
HOST_PROJECT_ROOT=/home/ubuntu/credit-risk-monitoring-pipeline
